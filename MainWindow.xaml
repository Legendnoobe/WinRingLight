<Window x:Class="WinRingLight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinRingLight"
        mc:Ignorable="d"
        Title="WinRingLight" 
        WindowStyle="None" 
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" 
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable Text, Segoe UI, Tahoma"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>
        <!-- Windows 11 Dark Mode style Button -->
        <Style x:Key="WindowsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D1D1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 11 style CheckBox -->
        <Style x:Key="WindowsCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="border" Width="18" Height="18" CornerRadius="4" 
                                        Background="#2D2D2D" BorderBrush="#404040" BorderThickness="1">
                                    <Path x:Name="checkMark" Data="M1,4.5 L4.5,8 L10,1" 
                                          Stroke="#FFFFFF" StrokeThickness="2" 
                                          Margin="3" Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="{TemplateBinding Padding}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#66FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowsButtonStyle}">
            <Setter Property="Width" Value="65"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <!-- Control Panel (Floating) -->
    <Border x:Name="ControlPanel" 
            Margin="20" 
            Background="#EE1A1A1A" 
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            CornerRadius="12" 
            Padding="20"
            Width="520"
            MouseLeftButtonDown="ControlPanel_MouseLeftButtonDown">
        
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>
        
        <StackPanel Orientation="Vertical">
            <Grid Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="24" Height="24" Margin="0,0,8,0">
                        <UniformGrid Columns="2" Rows="2">
                            <Border Background="#FFFFE0" CornerRadius="2" Margin="1" Width="10" Height="10"/>
                            <Border Background="#FFFFE0" CornerRadius="2" Margin="1" Width="10" Height="10"/>
                            <Border Background="#FFFFE0" CornerRadius="2" Margin="1" Width="10" Height="10"/>
                            <Border Background="#FFFFE0" CornerRadius="2" Margin="1" Width="10" Height="10"/>
                        </UniformGrid>
                    </Viewbox>
                    <TextBlock x:Name="TitleText" Text="Windows RingLight" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFFFF" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="LangBtn" Content="TR" Click="SwitchLanguage_Click" Background="Transparent" BorderThickness="0" Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,10,0"/>
                    <Button x:Name="ExitBtn" Content="Exit" Click="Exit_Click" Background="Transparent" BorderThickness="0" Foreground="#AAFFFFFF" FontSize="11"/>
                </StackPanel>
            </Grid>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Colors & Basic Controls -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="ColorText" Text="Colors" FontSize="11" Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                        <CheckBox x:Name="RgbModeCheckBox" Content="RGB" IsChecked="False" Foreground="#99FFFFFF" FontSize="10" Margin="10,0,0,0" VerticalAlignment="Center" Click="RgbModeCheckBox_Click"/>
                    </StackPanel>
                    
                    <Grid x:Name="ColorModesContainer">
                        <Grid x:Name="WhiteLightGrid" Margin="0,0,0,10" Visibility="Visible">
                            <Border Height="4" VerticalAlignment="Center" CornerRadius="2" Margin="5,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FFFFA4" Offset="0"/>
                                        <GradientStop Color="#FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="#58B0FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Slider x:Name="ColorSlider" Minimum="0" Maximum="1" Value="0.5" IsMoveToPointEnabled="True" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RgbPickerGrid" Margin="5,0,5,10" Visibility="Collapsed" Height="90">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>

                            <!-- Color Map (Saturation & Value) -->
                            <Grid x:Name="ColorMapGrid" MouseLeftButtonDown="ColorMap_MouseLeftButtonDown" MouseMove="ColorMap_MouseMove" MouseLeftButtonUp="ColorMap_MouseLeftButtonUp" LostMouseCapture="ColorMap_LostMouseCapture" Background="Transparent">
                                <Border x:Name="ColorMapHueLayer" Background="Red" CornerRadius="4,4,0,0"/>
                                <Border CornerRadius="4,4,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border CornerRadius="4,4,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                            <GradientStop Color="#FF000000" Offset="0"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Canvas x:Name="ColorMapCanvas" ClipToBounds="True" IsHitTestVisible="False">
                                    <Ellipse x:Name="ColorMapThumb" Width="12" Height="12" Stroke="White" StrokeThickness="1.5" Fill="Transparent">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform x:Name="ColorThumbTransform" X="100" Y="0" />
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Canvas>
                            </Grid>

                            <!-- Hue Slider -->
                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <Border Height="6" VerticalAlignment="Center" CornerRadius="3" Margin="5,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFFF0000" Offset="0.0"/>
                                            <GradientStop Color="#FFFFFF00" Offset="0.166"/>
                                            <GradientStop Color="#FF00FF00" Offset="0.333"/>
                                            <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                                            <GradientStop Color="#FF0000FF" Offset="0.666"/>
                                            <GradientStop Color="#FFFF00FF" Offset="0.833"/>
                                            <GradientStop Color="#FFFF0000" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Slider x:Name="HueSlider" Minimum="0" Maximum="360" Value="0" IsMoveToPointEnabled="True" ValueChanged="HueSlider_ValueChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Grid>
                    
                    <StackPanel x:Name="BrightnessGroup">
                        <TextBlock x:Name="BrightnessText" Text="Brightness (Dimmer)" FontSize="10" Foreground="#66FFFFFF" Margin="0,4,0,2"/>
                        <Slider x:Name="BrightnessSlider" Minimum="0" Maximum="0.9" Value="0.9" IsMoveToPointEnabled="True" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                    
                    <StackPanel x:Name="OpacityGroup">
                        <TextBlock x:Name="OpacityText" Text="Intensity (Solid)" FontSize="10" Foreground="#66FFFFFF" Margin="0,0,0,2"/>
                        <Slider x:Name="OpacitySlider" Minimum="0" Maximum="1.0" Value="1.0" IsMoveToPointEnabled="True" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>

                    <StackPanel x:Name="SoftnessGroup">
                        <TextBlock x:Name="SoftnessText" Text="Softness (Blur)" FontSize="10" Foreground="#66FFFFFF" Margin="0,0,0,2"/>
                        <Slider x:Name="SoftnessSlider" Minimum="0" Maximum="1" Value="0.1" IsMoveToPointEnabled="True" ValueChanged="Slider_ValueChanged" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Advanced Modes & Size -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock x:Name="ModesText" Text="Light Mode &amp; Size" FontSize="11" Foreground="#99FFFFFF" Margin="0,0,0,6"/>
                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <Button x:Name="ModeFullBtn" Content="Full" Click="Mode_Click" Tag="Full" Style="{StaticResource ModeButtonStyle}"/>
                        <Button x:Name="ModeSidesBtn" Content="Sides" Click="Mode_Click" Tag="Sides" Style="{StaticResource ModeButtonStyle}"/>
                        <Button x:Name="ModeTopBtn" Content="Top" Click="Mode_Click" Tag="Top" Style="{StaticResource ModeButtonStyle}"/>
                        <Button x:Name="ModeRingBtn" Content="Ring" Click="Mode_Click" Tag="Ring" Style="{StaticResource ModeButtonStyle}"/>
                        <Button x:Name="ModeRectBtn" Content="Frame" Click="Mode_Click" Tag="RoundedRect" Style="{StaticResource ModeButtonStyle}"/>
                        <Button x:Name="ModeMatrixBtn" Content="Matrix" Click="Mode_Click" Tag="Matrix" Style="{StaticResource ModeButtonStyle}"/>
                    </UniformGrid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="ThicknessGroup" Margin="0,0,5,0">
                            <TextBlock x:Name="ThicknessText" Text="Thickness" FontSize="10" Foreground="#66FFFFFF" Margin="0,0,0,2"/>
                            <Slider x:Name="ThicknessSlider" Minimum="0.05" Maximum="1.0" Value="0.4" IsMoveToPointEnabled="True" ValueChanged="Slider_ValueChanged"/>
                        </StackPanel>
                        <StackPanel x:Name="CornerGroup" Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock x:Name="CornerText" Text="Corner Radius" FontSize="10" Foreground="#66FFFFFF" Margin="0,0,0,2"/>
                            <Slider x:Name="CornerRadiusSlider" Minimum="0" Maximum="1.0" Value="0.2" IsMoveToPointEnabled="True" ValueChanged="Slider_ValueChanged"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="MatrixGroup" Visibility="Collapsed" Margin="0,5,0,0">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock x:Name="MatrixRowsText" Text="Rows: 3" FontSize="10" Foreground="#66FFFFFF" Margin="0,0,0,2"/>
                                <Slider x:Name="MatrixRowsSlider" Minimum="1" Maximum="10" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="MatrixSlider_ValueChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock x:Name="MatrixColsText" Text="Cols: 3" FontSize="10" Foreground="#66FFFFFF" Margin="0,0,0,2"/>
                                <Slider x:Name="MatrixColsSlider" Minimum="1" Maximum="10" Value="3" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="MatrixSlider_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                        <Button x:Name="MatrixBrushBtn" Content="Set Brush Color" FontSize="10" Margin="0,0,0,5" Padding="4" HorizontalAlignment="Center" Style="{StaticResource WindowsButtonStyle}" Click="MatrixBrushBtn_Click"/>
                        <Border BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="4" Padding="2" HorizontalAlignment="Center" Height="100" Width="170">
                            <UniformGrid x:Name="MatrixPreviewGrid" Rows="3" Columns="3"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="CaptureCheckBox" Content="Hide from Screen Capture" 
                      Style="{StaticResource WindowsCheckBoxStyle}" 
                      Click="CaptureCheckBox_Click" 
                      HorizontalAlignment="Center" Margin="0,10,0,0"/>

            <Separator Background="#22FFFFFF" Margin="0,15,0,10"/>
            <TextBlock x:Name="ShortcutText" Text="Shortcuts: 'Alt+H' (Panel), 'Alt+L' (Light), 'Esc' (Exit)" FontSize="10" Foreground="#44FFFFFF" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
